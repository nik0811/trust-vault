{
  "name": "@securelens/sdk",
  "version": "1.0.0",
  "description": "SecureLens AI Gate SDK for Node.js - Secure your RAG applications with enterprise-grade data governance",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./express": {
      "import": "./dist/esm/express.js",
      "require": "./dist/cjs/express.js",
      "types": "./dist/types/express.d.ts"
    },
    "./langchain": {
      "import": "./dist/esm/langchain.js",
      "require": "./dist/cjs/langchain.js",
      "types": "./dist/types/langchain.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "securelens",
    "ai-gate",
    "rag",
    "llm",
    "data-governance",
    "pii",
    "classification",
    "security",
    "compliance",
    "langchain",
    "openai",
    "anthropic"
  ],
  "author": "SecureLens",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/securelens/sdk-node.git"
  },
  "homepage": "https://securelens.ai/docs/sdk/node",
  "bugs": {
    "url": "https://github.com/securelens/sdk-node/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "langchain": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "langchain": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
