# TrustVault Frontend - Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Authentication
# JWT token is stored in httpOnly cookies automatically

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Feature Flags
NEXT_PUBLIC_ENABLE_LINEAGE_VISUALIZATION=true
NEXT_PUBLIC_ENABLE_ADVANCED_FILTERING=true
NEXT_PUBLIC_ENABLE_BATCH_OPERATIONS=true

# Theme
# System theme detection is enabled by default
# Users can toggle between light/dark modes

# Development
NODE_ENV=development
